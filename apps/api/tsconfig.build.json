{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "outDir": "dist",
        "module": "Node16",
        "moduleResolution": "Node16",
        "allowImportingTsExtensions": false,
        "verbatimModuleSyntax": false,
        "declaration": false,
        "sourceMap": false
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}