# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend & Auth
FRONTEND_URL="http://localhost:3000"
BETTER_AUTH_URL="http://localhost:3001"
BETTER_AUTH_SECRET="your-secret-here" # Generate with: openssl rand -base64 32

# Database
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/database" # Legacy/Prototype (optional)

# AI Services
OPENAI_API_KEY="sk-proj-your-openai-api-key-here"
ELEVENLABS_API_KEY="sk_your-elevenlabs-api-key-here"
UNREAL_SPEECH_API_KEY="your-unreal-speech-api-key-here"

# TTS Configuration
TTS_PROVIDER="unreal" # Options: 'unreal', 'elevenlabs'

# AWS / Storage (S3 or R2)
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_REGION="us-east-1"
S3_BUCKET_NAME="your-bucket-name"

# OAuth Providers (Optional)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Webhooks & Security (Optional)
API_KEYS="your-internal-api-key"
WEBHOOK_URL="http://localhost:3099/webhook"
WEBHOOK_SECRET="your-webhook-secret"

# Redis (for Queue)
REDIS_URL="redis://localhost:6379"

# Dodo Payments (Billing)
DODO_PAYMENTS_API_KEY="your-dodo-api-key-here"
DODO_PAYMENTS_WEBHOOK_KEY="your-dodo-webhook-secret-here"
DODO_PAYMENTS_ENVIRONMENT="test_mode" # Options: 'test_mode', 'live_mode'
DODO_PAYMENTS_RETURN_URL="http://localhost:3000/dashboard/settings/billing/success"

# Dodo Product IDs (from Dodo Dashboard)
DODO_PRODUCT_STARTER="pdt_your_starter_product_id"
DODO_PRODUCT_PRO="pdt_your_pro_product_id"
DODO_PRODUCT_BUSINESS="pdt_your_business_product_id"

# Admin Configuration
ADMIN_EMAILS="admin@example.com" # Comma-separated list of admin emails
